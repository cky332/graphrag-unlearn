# GraphRAG 删除流程所需的 API 配置
# 复制此文件为 .env 并填入实际值

# ============================================================
# LLM API 配置（删除流程需要调用 LLM）
# ============================================================
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1/
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ============================================================
# API 服务配置
# ============================================================

# 认证密钥（必填，未设置时拒绝所有请求）
GRAPHRAG_API_KEY=your-secret-api-key-here

# 数据缓存目录（默认 cache）
# GRAPHRAG_CACHE_DIR=cache

# 速率限制
# GRAPHRAG_DELETE_RATE_LIMIT=5/minute
# GRAPHRAG_QUERY_RATE_LIMIT=30/minute

# CORS 允许的来源（逗号分隔，默认允许所有）
# GRAPHRAG_CORS_ORIGINS=https://your-frontend.example.com

# 任务数据库路径（默认 tasks.db）
# GRAPHRAG_TASK_DB=tasks.db
